# Backend configuration for the Barangay Kinamlutan Water System API
# (Express + better-sqlite3 — see server/src/db/database.js)
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Required. Generate a long random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-this-secret

# Optional — only needed if resident Google Sign-In is enabled.
# See server/SETUP.md for how to create this in Google Cloud Console.
GOOGLE_CLIENT_ID=
